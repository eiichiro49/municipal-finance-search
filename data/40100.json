援学校費":715860,"幼稚園費":8254213,"社会教育費":216435,"保健体育費":11011375,"大学費":4396448}},"議会費":{"t":1544846,"i":{}},"労働費":{"t":455647,"i":{}},"公債費":{"t":70692504,"i":{}},"その他":{"t":0,"i":{"災害復旧費":172504,"諸支出金":643601,"前年度繰上充用金":0,"税関係交付金":0}}},"歳出 (性質)":{"人件費":{"t":111880669,"i":{}},"扶助費":{"t":175195788,"i":{}},"公債費":{"t":172504,"i":{}},"普通建設事業費":{"t":0,"i":{"補助":26508531,"単独":75936239,"国直轄":44268709}},"物件費":{"t":64593091,"i":{}},"補助費等":{"t":28923413,"i":{}},"その他":{"t":0,"i":{"災害復旧事業費":28360546,"維持補修費":7241143,"積立金":94589,"その他":0}}}},"stock":{"積立金":{"積立金現在高":{"財政調整基金":14133776,"減債基金":13120853,"その他特定目的基金":18125604}},"地方債":{"地方債現在高":{"地方債現在高(臨時財政対策債除く)":662476811,"臨時財政対策債":339701615}}},"comments":[{"label":"経常収支比率","text":"令和４年度は、地方交付税や臨時財政対策債の減少や、扶助費の増加等により99.3％と悪化したものの、令和５年度には、定年延長に伴う人件費の減少や、地方税等の経常一般財源の増等により、97.1％となりました。令和６年度については、退職手当による人件費や扶助費の増加、地方税や臨時財政対策債の減少により2.2ポイント増の99.3％となりました。\n　市税や地方交付税等の主要な一般財源が限られる中、福祉・医療関係経費の伸びが見込まれるなど、本市財政を取り巻く状況は引き続き厳しいことが見込まれます。今後とも一層の「選択と集中」を行いながら、行財政改革大綱に掲げた取組みを推進し、持続可能で安定的な財政の確立、維持に努めていきます。"},{"label":"歳出 (性質別)","text":"歳出決算総額は、住民一人当たり680,217円となっており、令和５年度から13,680円の増となっています。主な要因としては、退職手当、期末勤勉手当等に伴う人件費の増加により、一人当たりのコストは前年度から11,587円増の122,464円となりました。\nまた、補助費が、物価高騰関連事業の減少等により、一人当たりのコストは前年度から4,171円減の31,660円となりました。"},{"label":"歳出 (目的別)","text":"歳出決算総額は、住民一人当たり680,217円となっており、令和５年度から13,680円の増となっています。主な構成項目のうち、衛生費は、日明工場建設事業（ＰＦＩ）の事業費増加等に伴い前年度から10,803千円増加し62,961千円となっています。\nまた、民生費は障害福祉サービス事業等の増加により前年度から6,327円増加して262,395円となっています。"},{"label":"財政力指数","text":"令和６年度は、固定資産税や地方特例交付金の増により、基準財政収入額が増加したものの、社会保障関係経費や給与費などの増により基準財政需要額も増加となったため、前年度比増減なしの0.69となりました。\n　類似団体との比較では、人口の減少や高い高齢化率などの影響により、市民一人当たりの市税収入が類似団体の平均を下回っており、相対的に低い水準にあります。 \n　企業誘致などを通じて、民間投資や人材を呼び込むなど、税源の涵養に繋がる取り組みを強化し、歳入の確保に努めます。"},{"label":"実質公債費比率","text":"実質公債費比率は、令和６年度は10.6％となっています。\n　前年度から0.5ポイント増加しており、これは地方債元利償還金等が増加したことによるものです。\n　今後も地方債の活用にあたっては、事業の必要性を吟味した上で、施策の選択と集中を図り、適正な市債管理に努めます。"},{"label":"将来負担比率","text":"令和６年度の将来負担比率は、地方債の残高は増加したものの、標準財政規模が増加したことなどにより、前年度に比べ0.2ポイント減少し143.0%となりました。\n　しかし、類似団体平均と比較すると、依然として高い水準にあります。\n　将来負担額の大部分を地方債の残高が占めることから、投資的経費の選択と集中により事業量を縮減し、地方債残高の抑制を図ることで、さらなる比率の改善に努めます。"},{"label":"積立金現在高","text":"（増減理由）\n　財政調整基金については１８．６億円の減、減債基金は１４億円の増となりました。また、特定目的基金は都市高速鉄道等整備基金の減などにより４８．９億円の減となりました。基金全体としては、５３．５億円の減となっています。\n（今後の方針）\n　財政調整基金については、公共施設の老朽化に伴う維持補修費の増加や高齢化に伴う福祉・医療関係経費の増加等により、一定の基金取り崩しが想定されます。今後も、歳入、歳出の状況をみて取り崩しを検討することとなりますが、それぞれの基金の設置の趣旨に即して、適正な管理・運営に努めます。"}],"grp":[{"n":"財政力指数","v":0.83,"u":"'-"},{"n":"経常収支比率","v":0.97,"u":"割合"},{"n":"実質公債費比率","v":0.064,"u":"割合"},{"n":"将来負担比率","v":0.591549979,"u":"割合"}]}}