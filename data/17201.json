5,"i":{}},"その他":{"t":0,"i":{"災害復旧費":3190668,"諸支出金":567778,"前年度繰上充用金":0,"税関係交付金":0}}},"歳出 (性質)":{"人件費":{"t":25268498,"i":{}},"扶助費":{"t":60209168,"i":{}},"公債費":{"t":3190668,"i":{}},"普通建設事業費":{"t":0,"i":{"補助":16944861,"単独":26152512,"国直轄":10970481}},"物件費":{"t":32926744,"i":{}},"補助費等":{"t":18015034,"i":{}},"その他":{"t":0,"i":{"災害復旧事業費":13313283,"維持補修費":2438460,"積立金":1904961,"その他":0}}}},"stock":{"積立金":{"積立金現在高":{"財政調整基金":7385819,"減債基金":3812748,"その他特定目的基金":35651414}},"地方債":{"地方債現在高":{"地方債現在高(臨時財政対策債除く)":135624997,"臨時財政対策債":72246982}}},"comments":[{"label":"経常収支比率","text":"類似団体に比べて財政の弾力性、健全性は保たれている。引き続き、扶助費や公債費などの義務的経費の増嵩が予想されることから、行財政改革を徹底し、弾力性の維持に努めていく。"},{"label":"歳出 (性質別)","text":"人件費については、会計年度任用職員勤勉手当の創設等により会計年度任用職員の職員給が22.5％増したほか、人勧等の影響により職員給が2.9％の増となり、全体で7.3％の増となった。扶助費については、定額減税調整給付金等により3.6％の増、補助費等については、金沢の買い物応援商品券支援事業等により0.8％の増、維持補修費については、道路除排雪費の増等により43.6％の増となった。普通建設事業費については、城北市民運動公園補助整備事業費の減等により補助事業費は26.4％の減、南部共同調理場建設事業費の増等により単独事業費は6.2％の増となり、全体では11.3％の減となった。災害復旧事業費では、令和６年能登半島地震で被害を受けた施設の災害復旧費の増により228.2％の増となった。積立金については、文化スポーツ施設再整備積立基金積立金の増等により219.6％の増となった。繰出金は、後期高齢者医療広域連合医療費負担金等の増により2.3％の増となった。"},{"label":"歳出 (目的別)","text":"総務費は文化スポーツ施設再整備積立基金積立金の増などにより23.7％の増、民生費は定額減税調整給付金の増及び災害救助費の増などにより3.3％の増、衛生費は被災家屋公費解体事業費の増等により1.8％の増、農林水産業費は森林・林業基盤整備費の減などにより0.6％の減、商工費は金沢の買い物応援商品券支援事業費の増などにより1.0％の増、土木費は公園新設改良費の減などにより13.8％の減、教育費は兼六小学校移転整備事業費の増などにより9.8％の増、災害復旧費は令和６年能登半島地震で被害を受けた施設等の復旧費の増により228.2％の増、公債費は繰上償還の減などにより11.9％の減となった。"},{"label":"財政力指数","text":"類似団体の平均とほぼ同水準であり、今後も歳出削減や徴収率の向上等に取り組み、税財政基盤の強化に努めていく。"},{"label":"実質公債費比率","text":"類似団体の平均値を下回っており、地方債償還の進捗等により減少している。今後も、交付税措置のある有利な地方債の借入など、中期財政計画の着実な実践により、財政基盤の強化に努めていく。"},{"label":"将来負担比率","text":"令和６年度の将来負担比率は、20.7％と対前年比0.5％の増となっており、その要因としては、債務負担支出予定額の増によるものである。引き続き、中期財政計画の着実な実践により、財政基盤の強化に努めていく。"},{"label":"積立金現在高","text":"（増減理由）\n文化スポーツ施設再整備積立基金や教育福祉施設等再整備積立基金など、基金の有効活用に向けた計画的な積立てを実施したほか、令和６年能登半島地震復興基金を新たに積立てたことなどにより、基金全体として、約54億円の増額となった。\n（今後の方針）\n今後の財政需要を見据え、施設整備積立基金への積立てを実施し、基金の有効活用を図る。"}],"grp":[{"n":"財政力指数","v":0.76,"u":"'-"},{"n":"経常収支比率","v":0.932,"u":"割合"},{"n":"実質公債費比率","v":0.052000000000000005,"u":"割合"},{"n":"将来負担比率","v":0.166955587,"u":"割合"}]}}