4358,"大学費":2094957}},"議会費":{"t":985320,"i":{}},"労働費":{"t":702070,"i":{}},"公債費":{"t":24422632,"i":{}},"その他":{"t":0,"i":{"災害復旧費":1027612,"諸支出金":990401,"前年度繰上充用金":0,"税関係交付金":0}}},"歳出 (性質)":{"人件費":{"t":38529986,"i":{}},"扶助費":{"t":115828122,"i":{}},"公債費":{"t":1027612,"i":{}},"普通建設事業費":{"t":0,"i":{"補助":13561052,"単独":29586301,"国直轄":12261136}},"物件費":{"t":34570470,"i":{}},"補助費等":{"t":15149599,"i":{}},"その他":{"t":0,"i":{"災害復旧事業費":16544818,"維持補修費":1752087,"積立金":97677,"その他":0}}}},"stock":{"積立金":{"積立金現在高":{"財政調整基金":7946404,"減債基金":10332503,"その他特定目的基金":16076778}},"地方債":{"地方債現在高":{"地方債現在高(臨時財政対策債除く)":147992932,"臨時財政対策債":89886014}}},"comments":[{"label":"経常収支比率","text":"人件費や扶助費の増により数値が微増したが、今後も例年同様、厳しい状況になると考えている。\n　財政構造の弾力性を確保するため、今後も、自主財源の確保に努めるほか、市債借入額を抑制することによる公債費の縮減、人件費の抑制、行政改革の推進等による一般行政経費のさらなる削減に努める。"},{"label":"歳出 (性質別)","text":"物価高騰に係る経費や障害福祉に要する経費の増などにより、類似団体と比較して扶助費が高くなっている。\n　一方、人件費や物件費、補助費等は類似団体平均値より低くなっており、健全な財政に寄与しているものと考えられる。\n　今後も、事務の効率化を図るとともに、事業のしゅん別や見直しを行い、健全な財政運営に努めていく。"},{"label":"歳出 (目的別)","text":"物価高騰対応重点支援給付金支給事業等の支出により、民生費が類似団体の平均値より高くなっている。\n　社会保障関係経費については今後も増加が見込まれるが、市単独事業については、改めて費用対効果等を検証して、見直しを行うなど、扶助費の抑制に努める。"},{"label":"財政力指数","text":"市税などの自主財源が乏しく地方交付税や国庫支出金への依存度が高い財政構造にあり、類似団体平均値より低くなっている。\n　今後も、事務事業の抜本的な見直しと合理化を図るとともに、市税などの自主財源の確保に努める。"},{"label":"実質公債費比率","text":"元利償還金の減などにより比率が減少しており、類似団体平均値より低く、公債費負担の健全度は確保されていると考えている。\n　今後も、公債費の縮減等により財政の健全化に努める。"},{"label":"将来負担比率","text":"充当可能特定歳入の減などにより、前年に比べ増加している。\n　今後も、公債費の縮減等により財政の健全化に努める。"},{"label":"積立金現在高","text":"（増減理由）\n財政調整基金や市債管理基金等の取り崩しにより、基金全体としては約４９億円の減となった。\n（今後の方針）\n本市を取り巻く財政状況が今後一段と厳しくなることが予想されることから、財政調整基金、減債基金、建設事業基金の財政３基金の残高に配慮し、年度間の財源調整機能を果たせる額として、標準財政規模の２０％を目安に確保に努める。"}],"grp":[{"n":"財政力指数","v":0.76,"u":"'-"},{"n":"経常収支比率","v":0.932,"u":"割合"},{"n":"実質公債費比率","v":0.052000000000000005,"u":"割合"},{"n":"将来負担比率","v":0.166955587,"u":"割合"}]}}